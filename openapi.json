{
  "openapi": "3.0.0",
  "info": {
    "title": "HiFi API",
    "version": "1.0.0",
    "description": "API for products and newsletter subscription"
  },
  "servers": [
    {
      "url": "https://hifi-api-f4du.onrender.com"
    }
  ],
  "paths": {
    "/products": {
      "get": {
        "summary": "Get all products",
        "responses": {
          "200": {
            "description": "List of products"
          }
        }
      }
    },
    "/products/{param}": {
      "get": {
        "summary": "Get product by id or name",
        "parameters": [
          {
            "name": "param",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": { "description": "Product found" },
          "404": { "description": "Product not found" }
        }
      }
    },
    "/newsletter": {
      "get": {
        "summary": "Get all newsletter emails",
        "responses": {
          "200": {
            "description": "List of emails"
          }
        }
      },
      "post": {
        "summary": "Subscribe to newsletter",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string"
                  }
                }
              },
              "example": {
                "email": "test@example.com"
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Subscribed successfully" },
          "400": { "description": "Invalid email" }
        }
      }
    }
  }
}